//@version=6
indicator("Quarterly Theory Boxes | Auto NY Cycles", overlay=true, max_boxes_count=500, max_labels_count=500, max_lines_count=200)

const string NY_TZ = "America/New_York"
const int MINUTE_MS = 60 * 1000

cycleModeInput = input.string("Auto", "Cycle", options=["Auto", "22.5m", "90m", "6H", "1D", "1W", "1M"], group="Cycle Settings")
showLabels = input.bool(true, "Show Quarter Labels (Q1-Q4)", group="Display Settings")
showTrueOpen = input.bool(true, "Show True Open (Q2 Open)", group="Display Settings")
showCycleTag = input.bool(true, "Show Active Cycle Tag", group="Display Settings")
showHistoricalCycles = input.bool(false, "Show Historical Q Cycles", group="Display Settings")
historicalCyclesToKeep = input.int(20, "Historical Cycles To Keep", minval=1, maxval=100, group="Display Settings")
boxTransparency = input.int(85, "Box Transparency", minval=0, maxval=100, group="Display Settings")
borderWidth = input.int(1, "Box Border Width", minval=1, maxval=4, group="Display Settings")

colorQ1 = input.color(color.new(color.blue, 85), "Q1 - Accumulation", group="Colors")
colorQ2 = input.color(color.new(color.yellow, 85), "Q2 - Manipulation", group="Colors")
colorQ3 = input.color(color.new(color.orange, 85), "Q3 - Distribution", group="Colors")
colorQ4 = input.color(color.new(color.green, 85), "Q4 - Continuation/Reversal", group="Colors")
colorTrueOpen = input.color(color.new(color.red, 0), "True Open Line", group="Colors")
trueOpenWidth = input.int(2, "True Open Line Width", minval=1, maxval=5, group="Colors")

adjustTransparency(baseColor) =>
    color.new(color.rgb(color.r(baseColor), color.g(baseColor), color.b(baseColor)), boxTransparency)

safeMax(currentValue, nextValue) =>
    na(currentValue) ? nextValue : math.max(currentValue, nextValue)

safeMin(currentValue, nextValue) =>
    na(currentValue) ? nextValue : math.min(currentValue, nextValue)

quarterMidpoint(startBar, endBar) =>
    startBar + int(math.floor((endBar - startBar) / 2))

quarterName(qIndex) =>
    qIndex == 0 ? "Q1" : qIndex == 1 ? "Q2" : qIndex == 2 ? "Q3" : "Q4"

quarterColor(qIndex) =>
    qIndex == 0 ? colorQ1 : qIndex == 1 ? colorQ2 : qIndex == 2 ? colorQ3 : colorQ4

cycleLabel(cycleName) =>
    cycleName == "22.5m" ? "22.5m Micro" : cycleName == "90m" ? "90m Session" : cycleName == "6H" ? "6H Session" : cycleName == "1D" ? "Daily" : cycleName == "1W" ? "Weekly" : "Monthly"

isLeapYear(y) =>
    (y % 4 == 0 and y % 100 != 0) or y % 400 == 0

daysInMonth(y, m) =>
    m == 2 ? (isLeapYear(y) ? 29 : 28) : (m == 4 or m == 6 or m == 9 or m == 11 ? 30 : 31)

dayOffsetFromMonday(dow) =>
    dow == dayofweek.monday ? 0 : dow == dayofweek.tuesday ? 1 : dow == dayofweek.wednesday ? 2 : dow == dayofweek.thursday ? 3 : dow == dayofweek.friday ? 4 : dow == dayofweek.saturday ? 5 : 6

getDailyAnchor(ts) =>
    currentYear = year(ts, NY_TZ)
    currentMonth = month(ts, NY_TZ)
    currentDay = dayofmonth(ts, NY_TZ)
    todayAnchor = timestamp(NY_TZ, currentYear, currentMonth, currentDay, 18, 0)
    previousDayAnchor = timestamp(NY_TZ, currentYear, currentMonth, currentDay - 1, 18, 0)
    ts >= todayAnchor ? todayAnchor : previousDayAnchor

getTimeCycleStart(ts, cycleMs) =>
    anchor = getDailyAnchor(ts)
    cycleOffset = int(math.floor((ts - anchor) / cycleMs))
    anchor + cycleOffset * cycleMs

getTimeCycleQuarter(ts, cycleMs) =>
    cycleStartTs = getTimeCycleStart(ts, cycleMs)
    quarterMs = cycleMs / 4.0
    int(math.min(3, math.floor((ts - cycleStartTs) / quarterMs)))

getWeekStart(ts) =>
    dow = dayofweek(ts, NY_TZ)
    currentYear = year(ts, NY_TZ)
    currentMonth = month(ts, NY_TZ)
    currentDay = dayofmonth(ts, NY_TZ)
    timestamp(NY_TZ, currentYear, currentMonth, currentDay - dayOffsetFromMonday(dow), 0, 0)

getWeekQuarter(ts) =>
    dow = dayofweek(ts, NY_TZ)
    dow == dayofweek.monday ? 0 : dow == dayofweek.tuesday ? 1 : dow == dayofweek.wednesday ? 2 : 3

getMonthStart(ts) =>
    timestamp(NY_TZ, year(ts, NY_TZ), month(ts, NY_TZ), 1, 0, 0)

getMonthQuarter(ts) =>
    currentYear = year(ts, NY_TZ)
    currentMonth = month(ts, NY_TZ)
    currentDay = dayofmonth(ts, NY_TZ)
    totalDays = daysInMonth(currentYear, currentMonth)
    int(math.min(3, math.floor((currentDay - 1) * 4 / totalDays)))

getAutoCycle() =>
    chartSeconds = timeframe.in_seconds()
    timeframe.isseconds ? "22.5m" : chartSeconds <= 60 ? "90m" : chartSeconds <= 300 ? "6H" : chartSeconds <= 900 ? "1D" : chartSeconds <= 3600 ? "1W" : "1M"

activeCycle = cycleModeInput == "Auto" ? getAutoCycle() : cycleModeInput

int cycleStartTs = na
int quarterIndex = na

if activeCycle == "22.5m"
    cycleStartTs := getTimeCycleStart(time, int(22.5 * 60 * 1000))
    quarterIndex := getTimeCycleQuarter(time, int(22.5 * 60 * 1000))
else if activeCycle == "90m"
    cycleStartTs := getTimeCycleStart(time, 90 * MINUTE_MS)
    quarterIndex := getTimeCycleQuarter(time, 90 * MINUTE_MS)
else if activeCycle == "6H"
    cycleStartTs := getTimeCycleStart(time, 6 * 60 * MINUTE_MS)
    quarterIndex := getTimeCycleQuarter(time, 6 * 60 * MINUTE_MS)
else if activeCycle == "1D"
    cycleStartTs := getTimeCycleStart(time, 24 * 60 * MINUTE_MS)
    quarterIndex := getTimeCycleQuarter(time, 24 * 60 * MINUTE_MS)
else if activeCycle == "1W"
    cycleStartTs := getWeekStart(time)
    quarterIndex := getWeekQuarter(time)
else
    cycleStartTs := getMonthStart(time)
    quarterIndex := getMonthQuarter(time)

var quarterBoxes = array.new_box(4)
var quarterLabels = array.new_label(4)
var quarterHighs = array.new_float(4, na)
var quarterLows = array.new_float(4, na)
var quarterStartBars = array.new_int(4, na)
var quarterEndBars = array.new_int(4, na)
var historicalBoxes = array.new_box()
var historicalLabels = array.new_label()
var historicalTrueOpenLines = array.new_line()
var historicalTrueOpenLabels = array.new_label()

var line trueOpenLine = na
var label trueOpenLabel = na
var label cycleTagLabel = na
var float trueOpenPrice = na
var int trueOpenStartBar = na
var int lastCycleStartTs = na
var int lastQuarterIndex = na
var string lastCycleName = ""
var int historicalCycleCount = 0
var bool lastShowHistoricalCycles = false

updateQuarterVisual(qIndex) =>
    startBar = array.get(quarterStartBars, qIndex)
    endBar = array.get(quarterEndBars, qIndex)
    qHigh = array.get(quarterHighs, qIndex)
    qLow = array.get(quarterLows, qIndex)
    qColor = quarterColor(qIndex)
    existingBox = array.get(quarterBoxes, qIndex)
    if na(existingBox)
        existingBox := box.new(startBar, qHigh, endBar, qLow, bgcolor=adjustTransparency(qColor), border_color=qColor, border_width=borderWidth)
        array.set(quarterBoxes, qIndex, existingBox)
    else
        box.set_left(existingBox, startBar)
        box.set_right(existingBox, endBar)
        box.set_top(existingBox, qHigh)
        box.set_bottom(existingBox, qLow)
        box.set_bgcolor(existingBox, adjustTransparency(qColor))
        box.set_border_color(existingBox, qColor)
        box.set_border_width(existingBox, borderWidth)
    existingLabel = array.get(quarterLabels, qIndex)
    if showLabels
        labelX = quarterMidpoint(startBar, endBar)
        if na(existingLabel)
            existingLabel := label.new(labelX, qHigh, quarterName(qIndex), style=label.style_label_down, color=qColor, textcolor=color.black, size=size.tiny)
            array.set(quarterLabels, qIndex, existingLabel)
        else
            label.set_x(existingLabel, labelX)
            label.set_y(existingLabel, qHigh)
            label.set_text(existingLabel, quarterName(qIndex))
            label.set_color(existingLabel, qColor)
            label.set_textcolor(existingLabel, color.black)
    else if not na(existingLabel)
        label.delete(existingLabel)
        array.set(quarterLabels, qIndex, na)

if not showHistoricalCycles and lastShowHistoricalCycles
    if array.size(historicalBoxes) > 0
        for idx = 0 to array.size(historicalBoxes) - 1
            historicalBox = array.get(historicalBoxes, idx)
            if not na(historicalBox)
                box.delete(historicalBox)
    if array.size(historicalLabels) > 0
        for idx = 0 to array.size(historicalLabels) - 1
            historicalLabel = array.get(historicalLabels, idx)
            if not na(historicalLabel)
                label.delete(historicalLabel)
    if array.size(historicalTrueOpenLines) > 0
        for idx = 0 to array.size(historicalTrueOpenLines) - 1
            historicalLine = array.get(historicalTrueOpenLines, idx)
            if not na(historicalLine)
                line.delete(historicalLine)
    if array.size(historicalTrueOpenLabels) > 0
        for idx = 0 to array.size(historicalTrueOpenLabels) - 1
            historicalTrueOpenLabel = array.get(historicalTrueOpenLabels, idx)
            if not na(historicalTrueOpenLabel)
                label.delete(historicalTrueOpenLabel)
    array.clear(historicalBoxes)
    array.clear(historicalLabels)
    array.clear(historicalTrueOpenLines)
    array.clear(historicalTrueOpenLabels)
    historicalCycleCount := 0

isNewCycle = barstate.isfirst or activeCycle != lastCycleName or cycleStartTs != lastCycleStartTs
if isNewCycle
    shouldArchiveCycle = showHistoricalCycles and not barstate.isfirst
    for idx = 0 to 3
        existingBox = array.get(quarterBoxes, idx)
        if shouldArchiveCycle
            array.push(historicalBoxes, existingBox)
        else if not na(existingBox)
            box.delete(existingBox)
        existingLabel = array.get(quarterLabels, idx)
        if shouldArchiveCycle
            array.push(historicalLabels, existingLabel)
        else if not na(existingLabel)
            label.delete(existingLabel)
        array.set(quarterBoxes, idx, na)
        array.set(quarterLabels, idx, na)
        array.set(quarterHighs, idx, na)
        array.set(quarterLows, idx, na)
        array.set(quarterStartBars, idx, na)
        array.set(quarterEndBars, idx, na)
    if shouldArchiveCycle and showTrueOpen
        array.push(historicalTrueOpenLines, trueOpenLine)
    else if not na(trueOpenLine)
        line.delete(trueOpenLine)
    trueOpenLine := na
    if shouldArchiveCycle and showTrueOpen
        array.push(historicalTrueOpenLabels, trueOpenLabel)
    else if not na(trueOpenLabel)
        label.delete(trueOpenLabel)
    trueOpenLabel := na
    trueOpenPrice := na
    trueOpenStartBar := na
    if showHistoricalCycles and not barstate.isfirst
        historicalCycleCount := historicalCycleCount + 1
        if historicalCycleCount > historicalCyclesToKeep
            historicalCycleCount := historicalCyclesToKeep
            for idx = 0 to 3
                oldestBox = array.shift(historicalBoxes)
                if not na(oldestBox)
                    box.delete(oldestBox)
                oldestLabel = array.shift(historicalLabels)
                if not na(oldestLabel)
                    label.delete(oldestLabel)
            if array.size(historicalTrueOpenLines) > 0
                oldestTrueOpenLine = array.shift(historicalTrueOpenLines)
                if not na(oldestTrueOpenLine)
                    line.delete(oldestTrueOpenLine)
            if array.size(historicalTrueOpenLabels) > 0
                oldestTrueOpenLabel = array.shift(historicalTrueOpenLabels)
                if not na(oldestTrueOpenLabel)
                    label.delete(oldestTrueOpenLabel)

isQuarterStart = isNewCycle or quarterIndex != lastQuarterIndex

if isQuarterStart
    array.set(quarterStartBars, quarterIndex, bar_index)
    array.set(quarterEndBars, quarterIndex, bar_index)
    array.set(quarterHighs, quarterIndex, high)
    array.set(quarterLows, quarterIndex, low)
    if quarterIndex == 1
        trueOpenPrice := open
        trueOpenStartBar := bar_index

currentQuarterHigh = safeMax(array.get(quarterHighs, quarterIndex), high)
currentQuarterLow = safeMin(array.get(quarterLows, quarterIndex), low)
array.set(quarterHighs, quarterIndex, currentQuarterHigh)
array.set(quarterLows, quarterIndex, currentQuarterLow)
array.set(quarterEndBars, quarterIndex, bar_index)

for idx = 0 to 3
    startBar = array.get(quarterStartBars, idx)
    endBar = array.get(quarterEndBars, idx)
    qHigh = array.get(quarterHighs, idx)
    qLow = array.get(quarterLows, idx)
    if not na(startBar) and not na(endBar) and not na(qHigh) and not na(qLow)
        updateQuarterVisual(idx)

if showTrueOpen and not na(trueOpenPrice) and not na(trueOpenStartBar)
    trueOpenText = cycleLabel(activeCycle) + " True Open: " + str.tostring(trueOpenPrice, format.mintick)
    if na(trueOpenLine)
        trueOpenLine := line.new(trueOpenStartBar, trueOpenPrice, bar_index, trueOpenPrice, color=colorTrueOpen, width=trueOpenWidth)
    else
        line.set_xy1(trueOpenLine, trueOpenStartBar, trueOpenPrice)
        line.set_xy2(trueOpenLine, bar_index, trueOpenPrice)
        line.set_color(trueOpenLine, colorTrueOpen)
        line.set_width(trueOpenLine, trueOpenWidth)
    if na(trueOpenLabel)
        trueOpenLabel := label.new(trueOpenStartBar, trueOpenPrice, trueOpenText, style=label.style_label_left, color=colorTrueOpen, textcolor=color.white, size=size.tiny)
    else
        label.set_x(trueOpenLabel, trueOpenStartBar)
        label.set_y(trueOpenLabel, trueOpenPrice)
        label.set_text(trueOpenLabel, trueOpenText)
        label.set_color(trueOpenLabel, colorTrueOpen)
        label.set_textcolor(trueOpenLabel, color.white)
else if not showTrueOpen
    if not na(trueOpenLine)
        line.delete(trueOpenLine)
        trueOpenLine := na
    if not na(trueOpenLabel)
        label.delete(trueOpenLabel)
        trueOpenLabel := na
    if array.size(historicalTrueOpenLines) > 0
        for idx = 0 to array.size(historicalTrueOpenLines) - 1
            historicalLine = array.get(historicalTrueOpenLines, idx)
            if not na(historicalLine)
                line.delete(historicalLine)
    if array.size(historicalTrueOpenLabels) > 0
        for idx = 0 to array.size(historicalTrueOpenLabels) - 1
            historicalTrueOpenLabel = array.get(historicalTrueOpenLabels, idx)
            if not na(historicalTrueOpenLabel)
                label.delete(historicalTrueOpenLabel)
    array.clear(historicalTrueOpenLines)
    array.clear(historicalTrueOpenLabels)
else
    if not na(trueOpenLine)
        line.delete(trueOpenLine)
        trueOpenLine := na
    if not na(trueOpenLabel)
        label.delete(trueOpenLabel)
        trueOpenLabel := na

if showCycleTag
    cycleTagText = (cycleModeInput == "Auto" ? "Auto -> " : "Manual -> ") + cycleLabel(activeCycle) + " (NY)"
    cycleTagY = ta.highest(high, 50)
    if na(cycleTagLabel)
        cycleTagLabel := label.new(bar_index, cycleTagY, cycleTagText, style=label.style_label_upper_left, color=color.new(color.black, 65), textcolor=color.white, size=size.tiny)
    else
        label.set_x(cycleTagLabel, bar_index)
        label.set_y(cycleTagLabel, cycleTagY)
        label.set_text(cycleTagLabel, cycleTagText)
        label.set_color(cycleTagLabel, color.new(color.black, 65))
        label.set_textcolor(cycleTagLabel, color.white)
else if not na(cycleTagLabel)
    label.delete(cycleTagLabel)
    cycleTagLabel := na

lastCycleStartTs := cycleStartTs
lastQuarterIndex := quarterIndex
lastCycleName := activeCycle
lastShowHistoricalCycles := showHistoricalCycles
